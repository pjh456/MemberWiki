############################################
# MemberWiki global env example
# Copy to .env at repo root for local/devops usage.
############################################

########################
# Frontend (Vite)
########################
# API base path used by frontend http client.
# Example: http://localhost:8000/api/v1
VITE_API_BASE_URL=http://localhost:8000/api/v1

# Optional app title shown in UI.
VITE_APP_NAME=MemberWiki

########################
# Backend (FastAPI)
########################
APP_ENV=development
LOG_LEVEL=INFO

# Keep in sync with docs/api base url.
API_V1_PREFIX=/api/v1

# SQLite default for local development.
# For Postgres example:
# postgresql+psycopg://user:password@localhost:5432/memberwiki
DATABASE_URL=sqlite:///./backend/data/memberwiki.db

# JWT auth
JWT_SECRET_KEY=replace-with-a-strong-random-secret
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=14

# CORS
# Comma separated list.
CORS_ALLOW_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
CORS_ALLOW_CREDENTIALS=true

# Uploads
UPLOAD_DIR=./backend/data/uploads
UPLOAD_MAX_FILE_SIZE_MB=10
UPLOAD_ALLOWED_EXTENSIONS=jpg,jpeg,png,pdf
UPLOAD_DAILY_LIMIT_PER_USER=20

# Basic API limits
RATE_LIMIT_AUTH_PER_MINUTE=10
RATE_LIMIT_UPLOAD_PER_MINUTE=20

# Optional cache
REDIS_URL=redis://localhost:6379/0

# Optional request tracing
REQUEST_ID_HEADER=X-Request-ID

# Optional notifications (email/sms code)
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM=noreply@example.com
SMS_PROVIDER=
SMS_API_KEY=
SMS_API_SECRET=

